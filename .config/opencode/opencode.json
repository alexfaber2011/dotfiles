{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "permission": {
    "read": "allow",
    "grep": "allow",
    "list": "allow",
    "glob": "allow",
    "find": "allow",
    "todowrite": "allow",
    "todoedit": "allow",
    "explore": "allow",
    "webfetch": "allow",
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "rg *": "allow",
      "grep *": "allow",
      "rm *": "ask",
      "sudo *": "deny",
      "chmod *": "ask",
      "chown *": "ask",
      "head *": "allow",
      "sort *": "allow",
      "docker logs *": "allow",
      "yarn test *": "allow",
      "find *": "allow",
      "jq *": "allow",
      "sed *": "allow"
    },
    "edit": "ask"
  },
  "tools": {
    "playwright-test_*": false
  },
  "agent": {
    "playwright": {
      "mode": "all",
      "description": "Specialized agent for creating and running Playwright end-to-end tests",
      "tools": {
        "playwright-test_*": true
      },
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    }
  },
  "provider": {
    "unsloth": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Unsloth Studio",
      "options": {
        "baseURL": "{env:UNSLOTH_STUDIO_BASE_URL}",
        "apiKey": "{env:UNSLOTH_STUDIO_API_KEY}"
      },
      "models": {
        "Jackrong/Qwopus3.6-35B-A3B-v1-MTP-GGUF": {}
      }
    }
  }
}
